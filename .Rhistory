library(tidyverse)
library(vcd)
install.packages("vdc")
library(tidyverse)
library(vcd)
install.packages("vcd")
library(tidyverse)
library(vcd)
# PIB x Escolarização
cor(dados$pib_per_capita, dados$escolarizacao, method = "pearson")
cor(dados$pib_per_capita, dados$escolarizacao, method = "spearman")
cor(dados$pib_per_capita, dados$escolarizacao, method = "kendall")
# PIB x Mortalidade
cor(dados$pib_per_capita, dados$mortalidade_infantil, method = "pearson", use = "complete.obs")
cor(dados$pib_per_capita, dados$mortalidade_infantil, method = "spearman", use = "complete.obs")
cor(dados$pib_per_capita, dados$mortalidade_infantil, method = "kendall", use = "complete.obs")
# IDH x Escolarização
cor(dados$idhm, dados$escolarizacao, method = "pearson", use = "complete.obs")
cor(dados$idhm, dados$escolarizacao, method = "spearman", use = "complete.obs")
cor(dados$idhm, dados$escolarizacao, method = "kendall", use = "complete.obs")
# Mortalidade infantil x IDH
cor(dados$idhm, dados$mortalidade_infantil, method = "pearson", use = "complete.obs")
cor(dados$idhm, dados$mortalidade_infantil, method = "spearman", use = "complete.obs")
cor(dados$idhm, dados$mortalidade_infantil, method = "kendall", use = "complete.obs")
# Receitas x Despesas Municipais
cor(dados$despesas_brutas, dados$receitas_brutas, method = "pearson", use = "complete.obs")
cor(dados$despesas_brutas, dados$receitas_brutas, method = "spearman", use = "complete.obs")
cor(dados$despesas_brutas, dados$receitas_brutas, method = "kendall", use = "complete.obs")
kable(tabela_pib_mort, caption = "PIB per capita x Mortalidade Infantil")
