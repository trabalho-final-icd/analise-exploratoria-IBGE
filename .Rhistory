library(ggplot2)
library(paletteer)
library(MetBrewer)
library(scales)
library(readxl)
library(dplyr)
dados <- read_xlsx("../dados/BaseDadosIBGE_MG.xlsx")
source("../scripts/script.R")
dados <- dados %>%
mutate(
z_pib = as.numeric(scale(pib_per_capita)),
z_idhm = as.numeric(scale(idhm)),
z_escolarizacao = as.numeric(scale(escolarizacao)),
z_mortalidade = -as.numeric(scale(mortalidade_infantil))
)
library(dplyr)
dados <- dados %>%
mutate(
z_pib = as.numeric(scale(pib_per_capita)),
z_idhm = as.numeric(scale(idhm)),
z_escolarizacao = as.numeric(scale(escolarizacao)),
z_mortalidade = -as.numeric(scale(mortalidade_infantil))
)
head(dados)
dados <- dados %>%
mutate(
indice_desenvolvimento =
(z_pib +
z_idhm +
z_escolarizacao +
z_mortalidade) / 4
)
summary(dados$indice_desenvolvimento)
head(ranking)
ranking <- dados %>%
arrange(desc(indice_desenvolvimento))
head(ranking)
bottom10 <- ranking %>%
select(municipio, indice_desenvolvimento) %>%
slice((n()-9):n())
bottom10
dados <- dados %>%
mutate(
quartil_desenvolvimento =
ntile(indice_desenvolvimento, 4)
)
table(dados$quartil_desenvolvimento)
dados <- dados %>%
mutate(
categoria_desenvolvimento =
case_when(
quartil_desenvolvimento == 1 ~ "Baixo",
quartil_desenvolvimento == 2 ~ "Médio-Baixo",
quartil_desenvolvimento == 3 ~ "Médio-Alto",
quartil_desenvolvimento == 4 ~ "Alto"
)
)
library(ggplot2)
ggplot(top10,
aes(x = reorder(municipio,
indice_desenvolvimento),
y = indice_desenvolvimento,
fill = indice_desenvolvimento)) +
geom_col() +
coord_flip() +
scale_fill_gradientn(colors = cores) +
labs(
title = "Top 10 Municípios Mais Desenvolvidos de Minas Gerais",
x = "Município",
y = "Índice de Desenvolvimento"
) +
theme_minimal() +
theme(
legend.position = "none"
)
dados_rank <- dados %>%
filter(!is.na(indice_desenvolvimento))
nrow(dados_rank)
ranking <- dados_rank %>%
arrange(desc(indice_desenvolvimento))
head(ranking)
tail(ranking)
top10 <- ranking %>%
select(municipio, indice_desenvolvimento) %>%
slice(1:10)
top10
library(ggplot2)
ggplot(top10,
aes(x = reorder(municipio,
indice_desenvolvimento),
y = indice_desenvolvimento,
fill = indice_desenvolvimento)) +
geom_col() +
coord_flip() +
scale_fill_gradientn(colors = cores) +
labs(
title = "Top 10 Municípios Mais Desenvolvidos de Minas Gerais",
x = "Município",
y = "Índice de Desenvolvimento"
) +
theme_minimal() +
theme(
legend.position = "none"
)
library(dplyr)
# Padronização das variáveis
dados <- dados %>%
mutate(
z_pib = as.numeric(scale(pib_per_capita)),
z_idhm = as.numeric(scale(idhm)),
z_escolarizacao = as.numeric(scale(escolarizacao)),
z_mortalidade = -as.numeric(scale(mortalidade_infantil))
)
# Criação do índice de desenvolvimento
dados <- dados %>%
mutate(
indice_desenvolvimento =
(z_pib +
z_idhm +
z_escolarizacao +
z_mortalidade) / 4
)
# Remoção de municípios com dados faltantes
dados_rank <- dados %>%
filter(!is.na(indice_desenvolvimento))
# Ranking
ranking <- dados_rank %>%
arrange(desc(indice_desenvolvimento))
# Top 10 municípios
top10 <- ranking %>%
select(municipio, indice_desenvolvimento) %>%
slice(1:10)
# Quartis de desenvolvimento
dados_rank <- dados_rank %>%
mutate(
quartil_desenvolvimento =
ntile(indice_desenvolvimento, 4)
)
# Classificação dos municípios
dados_rank <- dados_rank %>%
mutate(
categoria_desenvolvimento =
case_when(
quartil_desenvolvimento == 1 ~ "Baixo",
quartil_desenvolvimento == 2 ~ "Médio-Baixo",
quartil_desenvolvimento == 3 ~ "Médio-Alto",
quartil_desenvolvimento == 4 ~ "Alto"
)
)
library(ggplot2)
ggplot(top10,
aes(x = reorder(municipio,
indice_desenvolvimento),
y = indice_desenvolvimento,
fill = indice_desenvolvimento)) +
geom_col() +
coord_flip() +
scale_fill_gradientn(colors = cores) +
labs(
title = "Top 10 Municípios Mais Desenvolvidos de Minas Gerais",
x = "Município",
y = "Índice de Desenvolvimento"
) +
theme_minimal() +
theme(
legend.position = "none"
)
