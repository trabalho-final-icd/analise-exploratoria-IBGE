dados$faixa_idhm <- cut(
dados$idhm,
breaks = quantile(
dados$idhm,
probs = seq(0, 1, 0.25),
na.rm = TRUE
),
include.lowest = TRUE
)
ggplot(
dados,
aes(
x = faixa_idhm,
y = mortalidade_infantil,
fill = faixa_idhm
)
) +
geom_boxplot() +
scale_fill_paletteer_d("MetBrewer::Pissaro") +
labs(
title = "Mortalidade Infantil por Faixa de IDHM",
x = "Faixa de IDHM",
y = "Mortalidade Infantil"
) +
