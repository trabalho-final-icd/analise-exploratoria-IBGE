estatisticas <- data.frame(
Variavel = names(numericas),
Media = round(sapply(numericas, mean, na.rm = TRUE), 2),
Mediana = round(sapply(numericas, median, na.rm = TRUE), 2),
Minimo = round(sapply(numericas, min, na.rm = TRUE), 2),
Maximo = round(sapply(numericas, max, na.rm = TRUE), 2),
DP = round(sapply(numericas, sd, na.rm = TRUE), 2),
CV = round(sapply(numericas, function(x) (sd(x, na.rm = TRUE) / mean(x, na.rm = TRUE)) * 100), 2)
)
# Filtrando só as 10 variáveis principais do relatório
colunas_principais <- c(
"area_territorial", "populacao", "densidade_demografica",
"populacao_estimada", "escolarizacao", "idhm",
"mortalidade_infantil", "receitas_brutas", "despesas_brutas", "pib_per_capita"
)
nomes_bonitos <- c(
area_territorial = "Área Territorial (km²)",
populacao = "População (Censo 2022)",
densidade_demografica = "Densidade Demográfica (hab/km²)",
populacao_estimada = "População Estimada (2025)",
escolarizacao = "Escolarização 6-14 anos (%)",
idhm = "IDHM",
mortalidade_infantil = "Mortalidade Infantil (óbitos/1000)",
receitas_brutas = "Receitas Brutas (R$)",
despesas_brutas = "Despesas Brutas (R$)",
pib_per_capita = "PIB per Capita (R$)"
)
estatisticas_tab <- estatisticas %>%
filter(Variavel %in% colunas_principais) %>%
mutate(Variavel = nomes_bonitos[Variavel]) %>%
select(Variável = Variavel, Média = Media, Mediana, `CV (%)` = CV)
gt(estatisticas_tab) %>%
tab_header(title = "Tabela 1: Medidas-resumo das variáveis") %>%
fmt_number(columns = where(is.numeric), decimals = 2, sep_mark = ".", dec_mark = ",") %>%
cols_align(align = "center", columns = where(is.numeric)) %>%
tab_options(
table.font.size = 13,
heading.title.font.size = 16,
column_labels.font.weight = "bold"
)
