) +
tema_trabalho
library(ggplot2)
quartis <- quantile(
dados$escolarizacao,
probs = c(0.25, 0.50, 0.75),
na.rm = TRUE
)
ggplot(dados, aes(x = escolarizacao)) +
geom_histogram(
bins = 10,
fill = "steelblue",
color = "black"
) +
geom_vline(
xintercept = quartis,
color = "red",
linetype = "dashed",
linewidth = 1
) +
labs(
title = "Histograma da Escolarização com Quartis",
x = "Escolarização",
y = "Frequência"
) +
theme_minimal()
