geom_point(
color = cores[3],
alpha = 0.7,
size = 2
) +
labs(
title = "IDHM e Escolarização",
x = "IDHM",
y = "Escolarização (%)"
) +
theme_minimal()
ggplot(
dados,
aes(
x = idhm,
y = mortalidade_infantil
)
) +
geom_point(
color = cores[4],
alpha = 0.7,
size = 2
) +
geom_smooth(
method = "lm",
se = TRUE,
color = cores[7]
) +
labs(
title = "IDHM e Mortalidade Infantil",
x = "IDHM",
y = "Mortalidade Infantil"
) +
theme_minimal()
ggplot(
dados,
aes(
x = receitas_brutas,
y = despesas_brutas
)
) +
geom_point(
color = cores[5],
alpha = 0.7,
size = 2
) +
scale_x_log10() +
scale_y_log10() +
labs(
title = "Receitas e Despesas Municipais",
x = "Receitas Brutas (R$) - escala log",
y = "Despesas Brutas (R$) - escala log"
) +
theme_minimal()
